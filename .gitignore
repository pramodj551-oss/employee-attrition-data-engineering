# ==========================================
# Employee Attrition Data Engineering
# .gitignore
# ==========================================

# -------------------------------
# Python
# -------------------------------
__pycache__/
*.py[cod]
*$py.class

# Compiled Extensions
*.so

# Distribution / Packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -------------------------------
# Virtual Environment
# -------------------------------
venv/
env/
ENV/
.venv/

# -------------------------------
# Jupyter Notebook
# -------------------------------
.ipynb_checkpoints/

# -------------------------------
# Environment Variables
# -------------------------------
.env

# -------------------------------
# SQLite Database
# -------------------------------
*.db
*.sqlite
*.sqlite3

# -------------------------------
# Logs
# -------------------------------
*.log
logs/
outputs/logs/

# -------------------------------
# Cache
# -------------------------------
.cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# -------------------------------
# IDE
# -------------------------------
.vscode/
.idea/

# -------------------------------
# Operating System Files
# -------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------------
# Temporary Files
# -------------------------------
*.tmp
*.temp

# -------------------------------
# Output Files
# -------------------------------
outputs/charts/
outputs/reports/

# Keep folder structure
!outputs/charts/.gitkeep
!outputs/reports/.gitkeep
!outputs/logs/.gitkeep

# -------------------------------
# Processed Data (Optional)
# -------------------------------
data/processed/*.csv

# Keep directory
!data/processed/.gitkeep

# -------------------------------
# Database Folder
# -------------------------------
data/database/*.db

# Keep folder
!data/database/.gitkeep
